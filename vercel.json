{
  "rewrites": [
    {
      "source": "/mockup-tema-quente.html",
      "destination": "/mockup-tema-quente.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/gerar-pdf.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/cron.js": {
      "maxDuration": 60
    },
    "api/instagram-publish.js": {
      "maxDuration": 60
    },
    "api/facebook-publish.js": {
      "maxDuration": 60
    },
    "api/whatsapp-webhook.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron?task=trial-emails",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron?task=tarefas",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron?task=email-sequencia",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron?task=instagram",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron?task=wa-sequencia",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron?task=wa-leads",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron?task=push-lembretes&bloco=manha",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron?task=push-lembretes&bloco=tarde",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron?task=push-lembretes&bloco=noite",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron?task=sync-expired",
      "schedule": "0 7 * * *"
    }
  ]
}
