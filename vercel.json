{
  "rewrites": [
    {
      "source": "/mockup-tema-quente.html",
      "destination": "/mockup-tema-quente.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/gerar-pdf.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/cron.js": {
      "maxDuration": 60
    },
    "api/instagram-publish.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron?task=trial-emails",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron?task=tarefas",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron?task=email-sequencia",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron?task=instagram",
      "schedule": "0 7 * * *"
    }
  ]
}
