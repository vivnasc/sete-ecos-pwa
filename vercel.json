{
  "rewrites": [
    {
      "source": "/mockup-tema-quente.html",
      "destination": "/mockup-tema-quente.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/gerar-pdf.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/tarefas-agendadas.js": {
      "maxDuration": 30
    },
    "api/email-sequencia.js": {
      "maxDuration": 30
    },
    "api/trial-expiring-emails.js": {
      "maxDuration": 30
    },
    "api/instagram-publish.js": {
      "maxDuration": 60
    },
    "api/instagram-schedule.js": {
      "maxDuration": 60
    },
    "api/whatsapp-webhook.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/trial-expiring-emails",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/tarefas-agendadas",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/email-sequencia",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/instagram-schedule",
      "schedule": "0 7 * * *"
    }
  ]
}
