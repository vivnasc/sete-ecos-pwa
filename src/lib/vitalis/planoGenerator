// lib/vitalis/planoGenerator.js
// Geração automática de plano nutricional baseado no intake

import { supabase } from '../supabase';

/**
 * Gera plano nutricional personalizado após preenchimento do intake
 * Baseado no método Precision Nutrition
 */
export async function gerarPlanoAutomatico(userId) {
  try {
    // 1. Buscar dados do intake
    const { data: intake, error: intakeError } = await supabase
      .from('vitalis_intake')
      .select('*')
      .eq('user_id', userId)
      .single();

    if (intakeError) throw intakeError;

    // 2. Buscar dados básicos do user
    const { data: user, error: userError } = await supabase
      .from('users')
      .select('altura_cm')
      .eq('id', userId)
      .single();

    if (userError) throw userError;

    // 3. Calcular TMB (Taxa Metabólica Basal) - Fórmula Mifflin-St Jeor
    const altura = intake.altura_cm || user.altura_cm;
    const peso = intake.peso_actual;
    const idade = intake.idade;
    const sexo = intake.sexo;

    let tmb;
    if (sexo === 'masculino') {
      tmb = (10 * peso) + (6.25 * altura) - (5 * idade) + 5;
    } else {
      tmb = (10 * peso) + (6.25 * altura) - (5 * idade) - 161;
    }

    // 4. Ajustar por nível de actividade
    const factoresActividade = {
      'sedentaria': 1.2,
      'leve': 1.375,
      'moderada': 1.55,
      'intensa': 1.725
    };
    const factor = factoresActividade[intake.nivel_actividade] || 1.2;
    const tdee = tmb * factor; // Total Daily Energy Expenditure

    // 5. Aplicar deficit/superavit baseado no objectivo
    let caloriasAlvo;
    const objectivo = intake.objectivo_principal;

    if (objectivo === 'perder_peso') {
      // Deficit de 20-25% (perda sustentável)
      caloriasAlvo = Math.round(tdee * 0.75);
    } else if (objectivo === 'ganhar_massa') {
      // Superavit de 10-15%
      caloriasAlvo = Math.round(tdee * 1.1);
    } else {
      // Manutenção
      caloriasAlvo = Math.round(tdee);
    }

    // 6. Calcular macros baseado na abordagem escolhida
    let proteinaG, carboidratosG, gorduraG;
    const abordagem = intake.abordagem_preferida || 'equilibrado';

    if (abordagem === 'keto_if') {
      // Keto: 70% gordura, 25% proteína, 5% carbs
      proteinaG = Math.round((caloriasAlvo * 0.25) / 4);
      carboidratosG = Math.round((caloriasAlvo * 0.05) / 4);
      gorduraG = Math.round((caloriasAlvo * 0.70) / 9);
    } else if (abordagem === 'low_carb') {
      // Low-carb: 40% proteína, 30% carbs, 30% gordura
      proteinaG = Math.round((caloriasAlvo * 0.40) / 4);
      carboidratosG = Math.round((caloriasAlvo * 0.30) / 4);
      gorduraG = Math.round((caloriasAlvo * 0.30) / 9);
    } else {
      // Equilibrado: 30% proteína, 40% carbs, 30% gordura
      proteinaG = Math.round((caloriasAlvo * 0.30) / 4);
      carboidratosG = Math.round((caloriasAlvo * 0.40) / 4);
      gorduraG = Math.round((caloriasAlvo * 0.30) / 9);
    }

    // 7. Converter para porções Precision Nutrition (método da mão)
    // 1 palma de proteína ≈ 25g proteína
    // 1 punho de legumes ≈ 50g legumes
    // 1 mão em concha de hidratos ≈ 30g hidratos
    // 1 polegar de gordura ≈ 10g gordura

    const porcoesProteina = Math.round(proteinaG / 25);
    const porcoesLegumes = 4; // Sempre 4 punhos por dia (fixo)
    const porcoesHidratos = Math.round(carboidratosG / 30);
    const porcoesGordura = Math.round(gorduraG / 10);

    // 8. Determinar número de refeições baseado no intake
    let numRefeicoes;
    if (intake.aceita_jejum && abordagem === 'keto_if') {
      numRefeicoes = 2; // Jejum intermitente: 2 refeições
    } else if (intake.num_refeicoes_dia) {
      numRefeicoes = parseInt(intake.num_refeicoes_dia.split('-')[0]);
    } else {
      numRefeicoes = 3; // Padrão
    }

    // 9. Distribuir porções por refeição
    const porcoesPorRefeicao = {
      proteina: Math.ceil(porcoesProteina / numRefeicoes),
      legumes: Math.ceil(porcoesLegumes / numRefeicoes),
      hidratos: Math.ceil(porcoesHidratos / numRefeicoes),
      gordura: Math.ceil(porcoesGordura / numRefeicoes)
    };

    // 10. Definir horários sugeridos baseado na rotina
    let horariosRefeicoes;
    if (intake.aceita_jejum) {
      // Jejum 16:8 - ex: 12h, 16h, 20h
      horariosRefeicoes = ['12:00', '16:00', '20:00'].slice(0, numRefeicoes);
    } else if (intake.pequeno_almoco === 'nunca') {
      // Não come pequeno-almoço
      horariosRefeicoes = ['13:00', '17:00', '20:00'].slice(0, numRefeicoes);
    } else {
      // Padrão
      horariosRefeicoes = ['08:00', '13:00', '19:00'].slice(0, numRefeicoes);
    }

    // 11. Determinar fase inicial
    const faseInicial = 'inducao';

    // 12. Função para converter prazo do formulário para formato do DB
    function converterPrazoParaDB(prazo) {
      const mapeamento = {
        '3m': '3_meses',
        '6m': '6_meses',
        '9m': '9_meses',
        '12m': '12_meses',
        'sem_pressa': 'sem_pressa'
      };
      return mapeamento[prazo] || '6_meses'; // Default: 6 meses
    }

    // 13. Criar/Atualizar registo em vitalis_clients com UPSERT
    const { error: clientError } = await supabase
      .from('vitalis_clients')
      .upsert({
        user_id: userId,
        status: 'activo',
        pacote: intake.pacote_escolhido || 'essencial',
        data_inicio: new Date().toISOString().split('T')[0],
        duracao_programa: converterPrazoParaDB(intake.prazo || intake.duracao || '6m'),
        fase_actual: faseInicial,
        objectivo_principal: intake.objectivo_principal,
        peso_inicial: intake.peso_actual,
        peso_actual: intake.peso_actual,
        peso_meta: intake.peso_meta,
        imc_inicial: calcularIMC(intake.peso_actual, altura),
        imc_actual: calcularIMC(intake.peso_actual, altura),
        emocao_dominante: intake.emocao_dominante,
        prontidao_1a10: intake.prontidao_1a10
      })
      .select();

    if (clientError) throw clientError;

    // 14. DESATIVAR planos antigos ANTES de criar novo (evita múltiplos ativos)
    await supabase
      .from('vitalis_meal_plans')
      .update({ status: 'inactivo' })
      .eq('user_id', userId)
      .eq('status', 'activo');

    // 15. Criar plano nutricional em vitalis_meal_plans
    const { data: plano, error: planoError } = await supabase
      .from('vitalis_meal_plans')
      .insert([{
        user_id: userId,
        versao: 1,
        fase: faseInicial,
        abordagem: abordagem,
        calorias_alvo: caloriasAlvo,
        proteina_g: proteinaG,
        carboidratos_g: carboidratosG,
        gordura_g: gorduraG,
        status: 'activo',
        receitas_incluidas: JSON.stringify({
          porções_por_refeicao: porcoesPorRefeicao,
          num_refeicoes: numRefeicoes,
          horarios: horariosRefeicoes
        })
      }])
      .select()
      .single();

    if (planoError) throw planoError;

    // 14. Criar hábitos iniciais da fase de indução
    const habitosInducao = [
      {
        habito: 'Beber 2L de água por dia',
        categoria: 'hidratacao',
        fase: 'inducao',
        dias_total: 14
      },
      {
        habito: 'Fazer 3 refeições dentro da janela alimentar',
        categoria: 'nutricao',
        fase: 'inducao',
        dias_total: 14
      },
      {
        habito: 'Dormir 7-8 horas por noite',
        categoria: 'sono',
        fase: 'inducao',
        dias_total: 14
      },
      {
        habito: 'Check-in diário na app',
        categoria: 'mindset',
        fase: 'inducao',
        dias_total: 14
      }
    ];

    const habitosComUserId = habitosInducao.map(h => ({
      ...h,
      user_id: userId,
      data_inicio: new Date().toISOString().split('T')[0]
    }));

    await supabase.from('vitalis_habitos').insert(habitosComUserId);

    // 15. Retornar resumo do plano gerado
    return {
      success: true,
      plano: {
        calorias: caloriasAlvo,
        macros: {
          proteina: proteinaG,
          carboidratos: carboidratosG,
          gordura: gorduraG
        },
        porcoes: {
          proteina: porcoesProteina,
          legumes: porcoesLegumes,
          hidratos: porcoesHidratos,
          gordura: porcoesGordura
        },
        porcoes_por_refeicao: porcoesPorRefeicao,
        num_refeicoes: numRefeicoes,
        horarios: horariosRefeicoes,
        fase: faseInicial,
        abordagem: abordagem
      }
    };

  } catch (error) {
    console.error('Erro ao gerar plano:', error);
    return {
      success: false,
      error: error.message
    };
  }
}

// Função auxiliar para calcular IMC
function calcularIMC(peso, altura) {
  const alturaM = altura / 100;
  return parseFloat((peso / (alturaM * alturaM)).toFixed(1));
}

// Função para recalcular plano (quando muda de fase ou peso estagna)
export async function recalcularPlano(userId, novaFase = null) {
  try {
    // 1. Buscar dados actuais do cliente
    const { data: client, error: clientError } = await supabase
      .from('vitalis_clients')
      .select('*')
      .eq('user_id', userId)
      .single();

    if (clientError) throw clientError;

    // 2. Buscar dados do intake original
    const { data: intake, error: intakeError } = await supabase
      .from('vitalis_intake')
      .select('*')
      .eq('user_id', userId)
      .single();

    if (intakeError) throw intakeError;

    // 3. Buscar plano actual
    const { data: planoActual, error: planoError } = await supabase
      .from('vitalis_meal_plans')
      .select('*')
      .eq('user_id', userId)
      .eq('status', 'activo')
      .single();

    if (planoError) throw planoError;

    // 4. Buscar altura do user
    const { data: user, error: userError } = await supabase
      .from('users')
      .select('altura_cm')
      .eq('id', userId)
      .single();

    if (userError) throw userError;

    // 5. Calcular TMB com peso actual (não o inicial)
    const altura = intake.altura_cm || user.altura_cm;
    const peso = client.peso_actual || intake.peso_actual;
    const idade = intake.idade;
    const sexo = intake.sexo;

    let tmb;
    if (sexo === 'masculino') {
      tmb = (10 * peso) + (6.25 * altura) - (5 * idade) + 5;
    } else {
      tmb = (10 * peso) + (6.25 * altura) - (5 * idade) - 161;
    }

    // 6. Ajustar por nível de actividade
    const factoresActividade = {
      'sedentaria': 1.2,
      'leve': 1.375,
      'moderada': 1.55,
      'intensa': 1.725
    };
    const factor = factoresActividade[intake.nivel_actividade] || 1.2;
    const tdee = tmb * factor;

    // 7. Determinar fase (usar nova fase se fornecida)
    const faseAnterior = client.fase_actual || 'inducao';
    const fase = novaFase || faseAnterior;

    // 8. Aplicar ajustes específicos por fase
    // Cada fase tem diferentes objectivos calóricos e de macros
    const ajustesFase = {
      'inducao': {
        // Fase 1: Deficit moderado, foco em criar hábitos
        deficitMultiplier: 0.80,  // 20% deficit
        proteinaRatio: 0.30,
        carboidratosRatio: 0.35,
        gorduraRatio: 0.35
      },
      'transicao': {
        // Fase 2: Deficit menor, aumentar carbs gradualmente
        deficitMultiplier: 0.85,  // 15% deficit
        proteinaRatio: 0.30,
        carboidratosRatio: 0.40,
        gorduraRatio: 0.30
      },
      'recomposicao': {
        // Fase 3: Próximo da manutenção, foco em recomposição corporal
        deficitMultiplier: 0.92,  // 8% deficit
        proteinaRatio: 0.35,      // Mais proteína para preservar músculo
        carboidratosRatio: 0.40,
        gorduraRatio: 0.25
      },
      'manutencao': {
        // Fase 4: Manutenção do peso alcançado
        deficitMultiplier: 1.0,   // Sem deficit
        proteinaRatio: 0.30,
        carboidratosRatio: 0.45,
        gorduraRatio: 0.25
      }
    };

    const ajuste = ajustesFase[fase] || ajustesFase['inducao'];

    // 9. Calcular calorias baseado no objectivo e fase
    let caloriasAlvo;
    const objectivo = intake.objectivo_principal;

    if (objectivo === 'perder_peso') {
      caloriasAlvo = Math.round(tdee * ajuste.deficitMultiplier);
    } else if (objectivo === 'ganhar_massa') {
      // Ganhar massa: inverter o deficit para superavit
      const superavitMultiplier = 1 + (1 - ajuste.deficitMultiplier);
      caloriasAlvo = Math.round(tdee * superavitMultiplier);
    } else {
      caloriasAlvo = Math.round(tdee);
    }

    // 10. Respeitar abordagem preferida se keto/low-carb
    const abordagem = intake.abordagem_preferida || 'equilibrado';
    let proteinaG, carboidratosG, gorduraG;

    if (abordagem === 'keto_if') {
      proteinaG = Math.round((caloriasAlvo * 0.25) / 4);
      carboidratosG = Math.round((caloriasAlvo * 0.05) / 4);
      gorduraG = Math.round((caloriasAlvo * 0.70) / 9);
    } else if (abordagem === 'low_carb') {
      proteinaG = Math.round((caloriasAlvo * 0.40) / 4);
      carboidratosG = Math.round((caloriasAlvo * 0.30) / 4);
      gorduraG = Math.round((caloriasAlvo * 0.30) / 9);
    } else {
      // Usar ratios da fase para abordagem equilibrada
      proteinaG = Math.round((caloriasAlvo * ajuste.proteinaRatio) / 4);
      carboidratosG = Math.round((caloriasAlvo * ajuste.carboidratosRatio) / 4);
      gorduraG = Math.round((caloriasAlvo * ajuste.gorduraRatio) / 9);
    }

    // 11. Converter para porções (método da mão)
    const porcoesProteina = Math.round(proteinaG / 25);
    const porcoesLegumes = 4;
    const porcoesHidratos = Math.round(carboidratosG / 30);
    const porcoesGordura = Math.round(gorduraG / 10);

    // 12. Manter configuração de refeições existente
    const configActual = planoActual.receitas_incluidas
      ? JSON.parse(planoActual.receitas_incluidas)
      : { num_refeicoes: 3 };

    const numRefeicoes = configActual.num_refeicoes || 3;
    const horariosRefeicoes = configActual.horarios || ['08:00', '13:00', '19:00'];

    const porcoesPorRefeicao = {
      proteina: Math.ceil(porcoesProteina / numRefeicoes),
      legumes: Math.ceil(porcoesLegumes / numRefeicoes),
      hidratos: Math.ceil(porcoesHidratos / numRefeicoes),
      gordura: Math.ceil(porcoesGordura / numRefeicoes)
    };

    // 13. Desactivar plano anterior
    await supabase
      .from('vitalis_meal_plans')
      .update({ status: 'inactivo' })
      .eq('id', planoActual.id);

    // 14. Criar novo plano com versão incrementada
    const { data: novoPlano, error: novoPlanoError } = await supabase
      .from('vitalis_meal_plans')
      .insert([{
        user_id: userId,
        versao: (planoActual.versao || 1) + 1,
        fase: fase,
        abordagem: abordagem,
        calorias_alvo: caloriasAlvo,
        proteina_g: proteinaG,
        carboidratos_g: carboidratosG,
        gordura_g: gorduraG,
        status: 'activo',
        receitas_incluidas: JSON.stringify({
          porções_por_refeicao: porcoesPorRefeicao,
          num_refeicoes: numRefeicoes,
          horarios: horariosRefeicoes
        })
      }])
      .select()
      .single();

    if (novoPlanoError) throw novoPlanoError;

    // 15. Actualizar fase do cliente se mudou
    if (novaFase && novaFase !== faseAnterior) {
      await supabase
        .from('vitalis_clients')
        .update({
          fase_actual: novaFase,
          imc_actual: calcularIMC(peso, altura)
        })
        .eq('user_id', userId);

      // 16. Criar hábitos para a nova fase
      const habitosPorFase = {
        'transicao': [
          { habito: 'Adicionar 1 porção extra de legumes', categoria: 'nutricao', dias_total: 14 },
          { habito: 'Praticar alimentação consciente', categoria: 'mindset', dias_total: 14 },
          { habito: 'Caminhar 30min por dia', categoria: 'movimento', dias_total: 14 }
        ],
        'recomposicao': [
          { habito: 'Treino de força 3x por semana', categoria: 'movimento', dias_total: 21 },
          { habito: 'Aumentar proteína em cada refeição', categoria: 'nutricao', dias_total: 21 },
          { habito: 'Registar progresso semanal', categoria: 'mindset', dias_total: 21 }
        ],
        'manutencao': [
          { habito: 'Manter rotina alimentar estabelecida', categoria: 'nutricao', dias_total: 28 },
          { habito: 'Variar treinos para manter motivação', categoria: 'movimento', dias_total: 28 },
          { habito: 'Praticar flexibilidade consciente', categoria: 'mindset', dias_total: 28 }
        ]
      };

      const novosHabitos = habitosPorFase[novaFase];
      if (novosHabitos) {
        const habitosComUserId = novosHabitos.map(h => ({
          ...h,
          user_id: userId,
          fase: novaFase,
          data_inicio: new Date().toISOString().split('T')[0]
        }));
        await supabase.from('vitalis_habitos').insert(habitosComUserId);
      }
    }

    // 17. Retornar resumo do plano recalculado
    return {
      success: true,
      plano: {
        calorias: caloriasAlvo,
        macros: {
          proteina: proteinaG,
          carboidratos: carboidratosG,
          gordura: gorduraG
        },
        porcoes: {
          proteina: porcoesProteina,
          legumes: porcoesLegumes,
          hidratos: porcoesHidratos,
          gordura: porcoesGordura
        },
        porcoes_por_refeicao: porcoesPorRefeicao,
        num_refeicoes: numRefeicoes,
        horarios: horariosRefeicoes,
        fase: fase,
        faseAnterior: faseAnterior,
        abordagem: abordagem,
        versao: (planoActual.versao || 1) + 1
      },
      mudancas: {
        faseMudou: fase !== faseAnterior,
        caloriasDiferenca: caloriasAlvo - planoActual.calorias_alvo
      }
    };

  } catch (error) {
    console.error('Erro ao recalcular plano:', error);
    return {
      success: false,
      error: error.message
    };
  }
}

export default {
  gerarPlanoAutomatico,
  recalcularPlano
};
